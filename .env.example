# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=app
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword

# Let's Encrypt (for ssl in sites.conf)
LETSENCRYPT_EMAIL=admin@example.com
# LETSENCRYPT_STAGING=1   # Use staging server for testing (avoids rate limits)

# WebSocket (Soketi) - must match Laravel broadcasting config
PUSHER_APP_ID=app-id
PUSHER_APP_KEY=app-key
PUSHER_APP_SECRET=app-secret
# SOKETI_DEBUG=1

# cp .env.example .env
